# Copy to .env and fill in. Never commit .env.

# ── Required ────────────────────────────────────────────────
# Get a free key at https://console.groq.com (Llama 3.3 70B is free-tier)
GROQ_API_KEY=

# ── Optional ────────────────────────────────────────────────
# Where the fs tool is allowed to look. Defaults to ./.workspace if unset.
# Path is resolved relative to the api/ working directory.
# CONTENT_ROOT=./.workspace

# Notion integration token. Without it, notion_* tools return mock data.
# Create at https://www.notion.so/my-integrations
# NOTION_TOKEN=

# ── Web ─────────────────────────────────────────────────────
# Override the dev proxy target if the api runs somewhere other than :8000
# VITE_API_URL=http://localhost:8000
